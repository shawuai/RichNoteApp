<Window x:Class="RichNoteApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="富云笔记" Height="750" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 笔记缩略项样式 -->
        <DataTemplate x:Key="NoteThumbnailTemplate">
            <Border CornerRadius="6" BorderBrush="#EEEEEE" BorderThickness="1" Margin="5" Padding="10" Background="White" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8F9FA"/>
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" Foreground="#333" 
                               TextTrimming="CharacterEllipsis" MaxHeight="40"/>
                    <TextBlock Text="{Binding PreviewContent}" FontSize="12" Foreground="#666" 
                               TextTrimming="CharacterEllipsis" MaxHeight="60" Margin="0,5,0,5"/>
                    <TextBlock Text="{Binding UpdatedAt, StringFormat='更新时间：{0:yyyy-MM-dd HH:mm}'}" 
                               FontSize="10" Foreground="#999"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <!-- 左侧分类区 -->
            <ColumnDefinition Width="200"/>
            <!-- 分隔线1 -->
            <ColumnDefinition Width="1"/>
            <!-- 中间笔记缩略列表区 -->
            <ColumnDefinition Width="400"/>
            <!-- 分隔线2 -->
            <ColumnDefinition Width="1"/>
            <!-- 右侧编辑区（默认隐藏） -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- === 左侧：分类管理区 === -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 分类操作按钮 -->
                <StackPanel Grid.Row="0" Margin="10,10,10,5" Orientation="Horizontal">
                    <Button x:Name="BtnAddMainCategory" Content="➕ 主分类" Click="BtnAddMainCategory_Click"
                            Background="#007ACC" Style="{StaticResource ModernButton}" Margin="0,0,5,0" FontSize="12"/>
                    <Button x:Name="BtnAddSubCategory" Content="➕ 子分类" Click="BtnAddSubCategory_Click"
                            Background="#28A745" Style="{StaticResource ModernButton}" FontSize="12"/>
                </StackPanel>

                <!-- 主分类列表 -->
                <ListBox x:Name="LstMainCategories" Grid.Row="1" Margin="5,0" Height="120"
                         SelectionChanged="LstMainCategories_SelectionChanged"
                         BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="8,5" FontSize="14" FontWeight="SemiBold"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" CornerRadius="4" Margin="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2196F3"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- 子分类列表 -->
                <ListBox x:Name="LstSubCategories" Grid.Row="2" Margin="5,10"
                         SelectionChanged="LstSubCategories_SelectionChanged"
                         BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="12,5" FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" CornerRadius="4" Margin="2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#90CAF9"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- 底部统计 -->
                <Border Grid.Row="3" Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="10,8">
                    <TextBlock x:Name="TxtCategoryCount" Text="分类：0" Foreground="#666" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <!-- === 分隔线1 === -->
        <Border Grid.Column="1" Background="#E0E0E0"/>

        <!-- === 中间：笔记缩略列表区 === -->
        <Border Grid.Column="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 笔记操作栏 -->
                <StackPanel Grid.Row="0" Margin="10,10,10,5" Orientation="Horizontal">
                    <Button x:Name="BtnNewNote" Content="➕ 新建笔记" Click="BtnNewNote_Click"
                            Background="#007ACC" Style="{StaticResource ModernButton}" FontSize="12"/>
                    <Button x:Name="BtnDeleteNote" Content="🗑️ 删除笔记" Click="BtnDeleteNote_Click"
                            Background="#DC3545" Style="{StaticResource ModernButton}" Margin="5,0,0,0" FontSize="12"/>
                </StackPanel>

                <!-- 笔记缩略列表 -->
                <ListBox x:Name="LstNoteThumbnails" Grid.Row="1" Margin="5,0"
                         SelectionChanged="LstNoteThumbnails_SelectionChanged"
                         ItemTemplate="{StaticResource NoteThumbnailTemplate}"
                         BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Vertical" Width="380"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- 底部统计 -->
                <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="10,8">
                    <TextBlock x:Name="TxtNoteCount" Text="笔记：0" Foreground="#666" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <!-- === 分隔线2 === -->
        <Border Grid.Column="3" Background="#E0E0E0"/>

        <!-- === 右侧：富文本编辑区（默认隐藏） === -->
        <Grid Grid.Column="4" Background="White" x:Name="GridEditor" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Margin="20,20,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtNoteTitle" FontSize="22" FontWeight="Bold"
                         BorderThickness="0,0,0,2" BorderBrush="#EEEEEE"
                         Background="Transparent" Padding="5"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnSaveNote" Content="💾 保存" Click="BtnSaveNote_Click"
                            Background="#28A745" Style="{StaticResource ModernButton}" Margin="0,0,5,0"/>
                    <Button x:Name="BtnCloseEditor" Content="❌ 关闭" Click="BtnCloseEditor_Click"
                            Background="#6c757d" Style="{StaticResource ModernButton}"/>
                </StackPanel>
            </Grid>

            <!-- WebView2富文本编辑器 -->
            <wv2:WebView2 x:Name="WebViewEditor" Grid.Row="1" Margin="20,0"/>

            <!-- 状态栏 -->
            <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="10,8">
                <Grid>
                    <TextBlock x:Name="TxtEditorStatus" Text="就绪" Foreground="#888" FontSize="12"/>
                    <TextBlock x:Name="TxtWordCount" Text="0 字" Foreground="#888" FontSize="12" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>